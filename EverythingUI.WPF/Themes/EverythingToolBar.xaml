<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/EverythingUI.WPF;component/Themes/EverythingScrollBar.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="EverythingToolBarItemBaseStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="4,2"/>
        <Setter Property="Height" Value="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid ClipToBounds="False">
                        <Border x:Name="border" CornerRadius="6" SnapsToDevicePixels="True"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>
                        <ContentPresenter x:Name="contentPresenter" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                        <!-- 悬停状态（未选中时显示浅色背景） -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value><SolidColorBrush Color="#F0F0F0" Opacity="0.8"/></Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="0.08" Color="Black" RenderingBias="Quality"/>
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EverythingToolBarHorizontalItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource EverythingToolBarItemBaseStyle}">
        <Setter Property="Padding" Value="12,0"/>
    </Style>

    <Style x:Key="EverythingToolBarVerticalItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource EverythingToolBarItemBaseStyle}">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Width" Value="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <DataTemplate x:Key="EverythingToolBarItemTextOnlyTemplate" DataType="{x:Type controls:EverythingToolBarItem}">
        <TextBlock Text="{Binding Text}" FontSize="13"/>
    </DataTemplate>

    <DataTemplate x:Key="EverythingToolBarItemIconOnlyTemplate" DataType="{x:Type controls:EverythingToolBarItem}">
        <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform"/>
    </DataTemplate>

    <DataTemplate x:Key="EverythingToolBarItemIconLeftTemplate" DataType="{x:Type controls:EverythingToolBarItem}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding Text}" FontSize="13" VerticalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EverythingToolBarItemIconTopTemplate" DataType="{x:Type controls:EverythingToolBarItem}">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform"/>
            <TextBlock Text="{Binding Text}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
    </DataTemplate>

    <Style TargetType="controls:EverythingToolBar">
        <Setter Property="MinHeight" Value="{Binding ToolBarHeight, RelativeSource={RelativeSource Self}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingToolBar">
                    <Grid ClipToBounds="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer x:Name="scrollViewer" Grid.Row="0" ClipToBounds="False"
                                      Padding="8,4"
                                      VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Hidden">
                            <Grid>
                                <!-- 选中指示器（与 ListBox 同级，共享坐标空间） -->
                                <Grid x:Name="selectionIndicator" Width="0" Height="0" Opacity="0" IsHitTestVisible="False"
                                      HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <Border x:Name="indicatorBackground" CornerRadius="6"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="{DynamicResource GlobalGradientStartColor}"/>
                                                <GradientStop Offset="0.5" Color="{DynamicResource GlobalGradientEndColor}"/>
                                                <GradientStop Offset="1" Color="{DynamicResource GlobalGradientStartColor}"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.25" Color="Black" RenderingBias="Quality"/>
                                        </Border.Effect>
                                    </Border>
                                    <Border x:Name="indicatorGloss" CornerRadius="6,6,0,0" Opacity="0.6"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Top"
                                            Background="{DynamicResource GlossBrush}" ClipToBounds="True" IsHitTestVisible="False"
                                            Height="{Binding Height, RelativeSource={RelativeSource AncestorType=Grid}, Converter={x:Static controls:HalfHeightConverter.Instance}}"/>
                                </Grid>
                                <ListBox x:Name="menuListBox"
                                         ItemsSource="{TemplateBinding ItemsSource}"
                                         ItemTemplate="{TemplateBinding ItemTemplate}"
                                         ItemContainerStyle="{DynamicResource EverythingToolBarHorizontalItemStyle}"
                                         SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                         Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                            </Grid>
                        </ScrollViewer>
                        <ScrollBar x:Name="PART_HorizontalScrollBar" Grid.Row="1" Orientation="Horizontal" Cursor="Arrow"
                                   Style="{DynamicResource EverythingHorizontalScrollBar}"
                                   Visibility="{Binding ComputedHorizontalScrollBarVisibility, ElementName=scrollViewer}"
                                   Maximum="{Binding ScrollableWidth, ElementName=scrollViewer}"
                                   ViewportSize="{Binding ViewportWidth, ElementName=scrollViewer}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ItemDisplayMode" Value="IconTop">
                            <Setter TargetName="menuListBox" Property="ItemContainerStyle" Value="{DynamicResource EverythingToolBarVerticalItemStyle}"/>
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingToolBarItemIconTopTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="IconOnly">
                            <Setter TargetName="menuListBox" Property="ItemContainerStyle" Value="{DynamicResource EverythingToolBarVerticalItemStyle}"/>
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingToolBarItemIconOnlyTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="IconLeft">
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingToolBarItemIconLeftTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="TextOnly">
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingToolBarItemTextOnlyTemplate}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
