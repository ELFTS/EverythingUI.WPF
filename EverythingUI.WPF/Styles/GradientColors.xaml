<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 所有渐变统一为 起始色(0) → 中间色(0.5) → 起始色(1)，配合顶部 GlossBrush 玻璃光泽 -->
    <!-- 主色 -->
    <Color x:Key="GradientWhiteStart">#FFFFFF</Color><Color x:Key="GradientWhiteEnd">#E6E6E6</Color>
    <Color x:Key="GradientBlackStart">#808080</Color><Color x:Key="GradientBlackEnd">#383838</Color>
    <Color x:Key="GradientGrayStart">#E5E5E5</Color><Color x:Key="GradientGrayEnd">#A6A6A6</Color>
    <Color x:Key="GradientRedStart">#FF5833</Color><Color x:Key="GradientRedEnd">#D43030</Color>
    <Color x:Key="GradientOrangeStart">#FFC300</Color><Color x:Key="GradientOrangeEnd">#FF8D1A</Color>
    <Color x:Key="GradientYellowStart">#FFEB3B</Color><Color x:Key="GradientYellowEnd">#FFC400</Color>
    <Color x:Key="GradientGreenStart">#A0D605</Color><Color x:Key="GradientGreenEnd">#19A654</Color>
    <Color x:Key="GradientCyanStart">#00BAAD</Color><Color x:Key="GradientCyanEnd">#00998F</Color>
    <Color x:Key="GradientBlueStart">#00ACF0</Color><Color x:Key="GradientBlueEnd">#0078D4</Color>
    <Color x:Key="GradientPurpleStart">#AC33C1</Color><Color x:Key="GradientPurpleEnd">#8D2C9E</Color>
    <Color x:Key="GradientPinkStart">#F7D7EC</Color><Color x:Key="GradientPinkEnd">#FF9CDB</Color>
    <!-- 扩展色 -->
    <Color x:Key="GradientIndigoStart">#5B7FFF</Color><Color x:Key="GradientIndigoEnd">#4A6BE5</Color>
    <Color x:Key="GradientSkyStart">#38BDF8</Color><Color x:Key="GradientSkyEnd">#0EA5E9</Color>
    <Color x:Key="GradientEmeraldStart">#34D399</Color><Color x:Key="GradientEmeraldEnd">#10B981</Color>
    <Color x:Key="GradientRoseStart">#FB7185</Color><Color x:Key="GradientRoseEnd">#E11D48</Color>
    <Color x:Key="GradientAmberStart">#FBBF24</Color><Color x:Key="GradientAmberEnd">#D97706</Color>
    <Color x:Key="GradientVioletStart">#8B5CF6</Color><Color x:Key="GradientVioletEnd">#7C3AED</Color>
    <Color x:Key="GradientCoralStart">#FF7F7F</Color><Color x:Key="GradientCoralEnd">#FF5252</Color>
    <Color x:Key="GradientMintStart">#6EE7B7</Color><Color x:Key="GradientMintEnd">#34D399</Color>
    <!-- 轨道色 -->
    <Color x:Key="TrackBlueColor">#E3F2FD</Color><Color x:Key="TrackRedColor">#FFEBEE</Color>
    <Color x:Key="TrackGreenColor">#E8F5E9</Color><Color x:Key="TrackPurpleColor">#F3E5F5</Color>
    <Color x:Key="TrackOrangeColor">#FFF3E0</Color><Color x:Key="TrackYellowColor">#FFFDE7</Color>
    <Color x:Key="TrackCyanColor">#E0F7FA</Color><Color x:Key="TrackPinkColor">#FCE4EC</Color>
    <Color x:Key="TrackGrayColor">#E6E6E6</Color>

    <!-- 渐变刷：每色一个垂直三色 LinearGradientBrush -->
    <LinearGradientBrush x:Key="GradientWhiteBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientWhiteStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientWhiteEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientWhiteStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientBlackBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientBlackStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientBlackEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientBlackStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientGrayBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientGrayStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientGrayEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientGrayStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientRedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientRedStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientRedEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientRedStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientOrangeBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientOrangeStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientOrangeEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientOrangeStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientYellowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientYellowStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientYellowEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientYellowStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientGreenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientGreenStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientGreenEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientGreenStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientCyanBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientCyanStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientCyanEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientCyanStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientBlueBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientBlueStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientBlueEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientBlueStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientPurpleBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientPurpleStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientPurpleEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientPurpleStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientPinkBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientPinkStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientPinkEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientPinkStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientIndigoBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientIndigoStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientIndigoEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientIndigoStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientSkyBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientSkyStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientSkyEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientSkyStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientEmeraldBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientEmeraldStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientEmeraldEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientEmeraldStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientRoseBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientRoseStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientRoseEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientRoseStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientAmberBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientAmberStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientAmberEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientAmberStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientVioletBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientVioletStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientVioletEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientVioletStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientCoralBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientCoralStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientCoralEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientCoralStart}"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GradientMintBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="{StaticResource GradientMintStart}"/>
        <GradientStop Offset="0.5" Color="{StaticResource GradientMintEnd}"/>
        <GradientStop Offset="1" Color="{StaticResource GradientMintStart}"/>
    </LinearGradientBrush>

    <!-- 统一白色光泽层：所有控件顶部高光（VerticalAlignment=Top + HalfHeightConverter） -->
    <LinearGradientBrush x:Key="GlossBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#CCFFFFFF"/>
        <GradientStop Offset="1" Color="#33FFFFFF"/>
    </LinearGradientBrush>

    <!-- 纯色画刷（用于卡片标题栏等） -->
    <SolidColorBrush x:Key="SolidRedBrush" Color="{StaticResource GradientRedStart}"/>
    <SolidColorBrush x:Key="SolidGreenBrush" Color="{StaticResource GradientGreenStart}"/>
    <SolidColorBrush x:Key="SolidOrangeBrush" Color="{StaticResource GradientOrangeStart}"/>
    <SolidColorBrush x:Key="SolidPurpleBrush" Color="{StaticResource GradientPurpleStart}"/>
    <SolidColorBrush x:Key="SolidBlueBrush" Color="{StaticResource GradientBlueStart}"/>
    <SolidColorBrush x:Key="SolidYellowBrush" Color="{StaticResource GradientYellowStart}"/>
    <SolidColorBrush x:Key="SolidCyanBrush" Color="{StaticResource GradientCyanStart}"/>
    <SolidColorBrush x:Key="SolidPinkBrush" Color="{StaticResource GradientPinkStart}"/>
    <SolidColorBrush x:Key="SolidBlackBrush" Color="{StaticResource GradientBlackEnd}"/>
    <SolidColorBrush x:Key="SolidGrayBrush" Color="{StaticResource GradientGrayEnd}"/>
    <SolidColorBrush x:Key="SolidWhiteBrush" Color="{StaticResource GradientWhiteEnd}"/>
</ResourceDictionary>
