<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <LinearGradientBrush x:Key="CardLightGrayGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#FAFAFA"/>
        <GradientStop Offset="0.5" Color="#F5F5F5"/>
        <GradientStop Offset="1" Color="#EEEEEE"/>
    </LinearGradientBrush>

    <Style TargetType="controls:EverythingCard">
        <Setter Property="Background" Value="{DynamicResource CardLightGrayGradientBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="ShadowDepth" Value="8"/>
        <Setter Property="FooterPadding" Value="16,0,16,16"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingCard">
                    <Grid>
                        <Border x:Name="shadowBorder" CornerRadius="{TemplateBinding CornerRadius}" Background="White" Opacity="0.15" IsHitTestVisible="False">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="{TemplateBinding ShadowDepth}" Opacity="1" Color="Black" RenderingBias="Quality"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ContentPresenter x:Name="contentPresenter" Grid.Row="0" Focusable="False"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                <ContentPresenter x:Name="footerPresenter" Grid.Row="1"
                                                  Content="{TemplateBinding Footer}" ContentTemplate="{TemplateBinding FooterTemplate}"
                                                  Margin="{TemplateBinding FooterPadding}"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Footer" Value="{x:Null}">
                            <Setter TargetName="footerPresenter" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="CardVariant" Value="Default">
                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            <Setter TargetName="shadowBorder" Property="Opacity" Value="0.12"/>
                            <Setter Property="ShadowDepth" Value="8"/>
                        </Trigger>
                        <Trigger Property="CardVariant" Value="Elevated">
                            <Setter TargetName="border" Property="BorderThickness" Value="0"/>
                            <Setter Property="ShadowDepth" Value="16"/>
                            <Setter TargetName="shadowBorder" Property="Opacity" Value="0.2"/>
                        </Trigger>
                        <Trigger Property="CardVariant" Value="Outlined">
                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            <Setter TargetName="shadowBorder" Property="Opacity" Value="0.1"/>
                            <Setter Property="ShadowDepth" Value="10"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
