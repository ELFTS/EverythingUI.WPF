<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 浅灰渐变背景 -->
    <LinearGradientBrush x:Key="CardLightGrayGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#FAFAFA"/>
        <GradientStop Offset="0.5" Color="#F5F5F5"/>
        <GradientStop Offset="1" Color="#EEEEEE"/>
    </LinearGradientBrush>

    <!-- 标题栏渐变背景 - 与按钮样式一致 -->
    <LinearGradientBrush x:Key="CardHeaderGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#5B7FFF"/>
        <GradientStop Offset="0.5" Color="#4A6BE5"/>
        <GradientStop Offset="1" Color="#5B7FFF"/>
    </LinearGradientBrush>

    <!-- 标题栏光泽效果 -->
    <LinearGradientBrush x:Key="CardHeaderGlossyBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#60FFFFFF"/>
        <GradientStop Offset="0.5" Color="#20FFFFFF"/>
        <GradientStop Offset="0.5" Color="#00FFFFFF"/>
    </LinearGradientBrush>

    <!-- Default Card Style -->
    <Style x:Key="DefaultCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardLightGrayGradientBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="0"
                                  BlurRadius="4"
                                  Opacity="0.08"
                                  Color="Black"
                                  RenderingBias="Quality"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Elevated Card Style -->
    <Style x:Key="ElevatedCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardLightGrayGradientBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="0"
                                  BlurRadius="12"
                                  Opacity="0.15"
                                  Color="Black"
                                  RenderingBias="Quality"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Outlined Card Style -->
    <Style x:Key="OutlinedCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardLightGrayGradientBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{x:Null}"/>
    </Style>

    <!-- 带标题栏的卡片样式 -->
    <Style x:Key="HeaderCardStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="0"
                                  BlurRadius="8"
                                  Opacity="0.1"
                                  Color="Black"
                                  RenderingBias="Quality"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 标题栏样式 - 与按钮一致 -->
    <Style x:Key="CardHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardHeaderGradientBrush}"/>
        <Setter Property="CornerRadius" Value="8,8,0,0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.2" Color="Black" RenderingBias="Quality"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 标题栏文字样式 -->
    <Style x:Key="CardHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
