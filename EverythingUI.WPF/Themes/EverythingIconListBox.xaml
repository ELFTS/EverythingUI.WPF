<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/EverythingUI.WPF;component/Themes/EverythingScrollBar.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- 列表项样式 -->
    <Style x:Key="IconListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid x:Name="rootGrid"
                          Width="{Binding ItemWidth, RelativeSource={RelativeSource AncestorType=controls:EverythingIconListBox}}"
                          Height="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=controls:EverythingIconListBox}}">
                        <!-- 主背景层 -->
                        <Border x:Name="border" SnapsToDevicePixels="True"
                                Background="Transparent"
                                CornerRadius="{Binding ItemCornerRadius, RelativeSource={RelativeSource AncestorType=controls:EverythingIconListBox}}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Border x:Name="hoverBackground" Background="Transparent"
                                        CornerRadius="{Binding ItemCornerRadius, RelativeSource={RelativeSource AncestorType=controls:EverythingIconListBox}}"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <!-- 键盘焦点边框 -->
                        <Border x:Name="focusBorder" Opacity="0" IsHitTestVisible="False" BorderThickness="2" BorderBrush="{DynamicResource PrimaryBrush}"
                                CornerRadius="{Binding ItemCornerRadius, RelativeSource={RelativeSource AncestorType=controls:EverythingIconListBox}}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- 选中状态（仅文字颜色变化，视觉由悬浮指示器提供） -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <!-- 悬停状态（未选中时） -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.15" Color="Black" RenderingBias="Quality"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="hoverBackground" Property="Background" Value="{DynamicResource Gray200Brush}"/>
                        </MultiTrigger>
                        <!-- 键盘焦点（仅在未选中时显示，避免选中时出现边框） -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="focusBorder" Property="Opacity" Value="0.6"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 主控件样式 -->
    <Style TargetType="controls:EverythingIconListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingIconListBox">
                    <Border SnapsToDevicePixels="True"
                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ScrollViewer x:Name="PART_ScrollViewer" Padding="8" Style="{DynamicResource EverythingScrollViewerStyle}"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <!-- 选中指示器（与 ListBox 同级，共享坐标空间） -->
                                <Grid x:Name="selectionIndicator" Width="0" Height="0" Opacity="0" IsHitTestVisible="False"
                                      HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <Border x:Name="indicatorBackground"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="{Binding ItemCornerRadius, RelativeSource={RelativeSource AncestorType=controls:EverythingIconListBox}}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="{DynamicResource GlobalGradientStartColor}"/>
                                                <GradientStop Offset="0.5" Color="{DynamicResource GlobalGradientEndColor}"/>
                                                <GradientStop Offset="1" Color="{DynamicResource GlobalGradientStartColor}"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.25" Color="Black" RenderingBias="Quality"/>
                                        </Border.Effect>
                                    </Border>
                                    <Border x:Name="indicatorGloss" Opacity="0.6"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Top"
                                            Background="{DynamicResource GlossBrush}" ClipToBounds="True" IsHitTestVisible="False"
                                            CornerRadius="{Binding ItemCornerRadius, RelativeSource={RelativeSource AncestorType=controls:EverythingIconListBox}}"
                                            Height="{Binding Height, RelativeSource={RelativeSource AncestorType=Grid}, Converter={x:Static controls:HalfHeightConverter.Instance}}"/>
                                </Grid>
                                <ListBox x:Name="PART_ListBox"
                                         ItemsSource="{TemplateBinding ItemsSource}"
                                         ItemContainerStyle="{StaticResource IconListBoxItemStyle}"
                                         SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                         Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
