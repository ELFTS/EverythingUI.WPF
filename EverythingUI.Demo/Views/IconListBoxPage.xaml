                                                            GradientEndColor="{StaticResource GradientRedEnd}">
                                <controls:EverythingIconListBox.ItemsSource>
                                    <x:Array Type="controls:EverythingIconListBoxItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                        <controls:EverythingIconListBoxItem Text="工具1">
                                            <controls:EverythingIconListBoxItem.Icon>
                                                <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                            </controls:EverythingIconListBoxItem.Icon>
                                        </controls:EverythingIconListBoxItem>
                                        <controls:EverythingIconListBoxItem Text="工具2">
                                            <controls:EverythingIconListBoxItem.Icon>
                                                <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                            </controls:EverythingIconListBoxItem.Icon>
                                        </controls:EverythingIconListBoxItem>
                                        <controls:EverythingIconListBoxItem Text="工具3">
                                            <controls:EverythingIconListBoxItem.Icon>
                                                <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                            </controls:EverythingIconListBoxItem.Icon>
                                        </controls:EverythingIconListBoxItem>
                                        <controls:EverythingIconListBoxItem Text="工具4">
                                            <controls:EverythingIconListBoxItem.Icon>
                                                <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                            </controls:EverythingIconListBoxItem.Icon>
                                        </controls:EverythingIconListBoxItem>
                                    </x:Array>
                                </controls:EverythingIconListBox.ItemsSource>
                            </controls:EverythingIconListBox>
                        </StackPanel>
                    </Border>

                    <Border Height="220" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                        <StackPanel>
                            <TextBlock Text="绿色" 
                                       FontSize="11" 
                                       Margin="8,4"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <controls:EverythingIconListBox Height="180"
                                                            ItemWidth="80"
                                                            ItemHeight="80"
                                                            IconSize="28"
                                                            TextFontSize="12"
                                                            CornerRadius="8"
                                                            GradientStartColor="{StaticResource GradientGreenStart}"
                                                            GradientEndColor="{StaticResource GradientGreenEnd}">
                                <controls:EverythingIconListBox.ItemsSource>
