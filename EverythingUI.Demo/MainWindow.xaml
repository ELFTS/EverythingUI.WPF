<Window x:Class="EverythingUI.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF"
        Title="EverythingUI 组件库测试程序"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 顶部颜色切换栏 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="主题颜色：" 
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ComboBox x:Name="ColorComboBox"
                          Width="120"
                          VerticalAlignment="Center"
                          SelectionChanged="ColorComboBox_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- 左侧导航侧边栏 -->
        <controls:EverythingSideBar x:Name="SideBar"
                                    Grid.Row="1" Grid.Column="0"
                                    SideBarWidth="250"
                                    CornerRadius="0,16,16,0"
                                    SelectedItem="{Binding SelectedCategory, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
            <controls:EverythingSideBar.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Text}" FontSize="14" FontWeight="Medium"/>
                </DataTemplate>
            </controls:EverythingSideBar.ItemTemplate>
        </controls:EverythingSideBar>

        <!-- 右侧内容区域 -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource EverythingScrollViewerStyle}">
            <ContentControl x:Name="ContentFrame" Margin="30"/>
        </ScrollViewer>
    </Grid>
</Window>
