<UserControl x:Class="EverythingUI.Demo.Views.CircularProgressBarPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
    <StackPanel>
        <TextBlock Text="圆形进度条控件"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- 基础圆形进度条 -->
        <TextBlock Text="基础圆形进度条" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <UniformGrid Columns="4" Rows="1">
                <controls:EverythingCircularProgressBar Value="0" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="25" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="50" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="75" Margin="10"/>
            </UniformGrid>
        </controls:EverythingCard>

        <!-- 带百分比显示 -->
        <TextBlock Text="带百分比显示" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <UniformGrid Columns="4" Rows="1">
                <controls:EverythingCircularProgressBar Value="0" ShowPercentage="True" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="33" ShowPercentage="True" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="66" ShowPercentage="True" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="100" ShowPercentage="True" Margin="10"/>
            </UniformGrid>
        </controls:EverythingCard>

        <!-- 不同颜色（使用颜色资源名称） -->
        <TextBlock Text="不同颜色（使用颜色资源名称）" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <UniformGrid Columns="4" Rows="1">
                <controls:EverythingCircularProgressBar Value="75" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="75" Margin="10"
                                                        GradientStartColor="{StaticResource GradientRedStart}" 
                                                        GradientEndColor="{StaticResource GradientRedEnd}"/>
                <controls:EverythingCircularProgressBar Value="75" Margin="10"
                                                        GradientStartColor="{StaticResource GradientGreenStart}" 
                                                        GradientEndColor="{StaticResource GradientGreenEnd}"/>
                <controls:EverythingCircularProgressBar Value="75" Margin="10"
                                                        GradientStartColor="{StaticResource GradientOrangeStart}" 
                                                        GradientEndColor="{StaticResource GradientOrangeEnd}"/>
            </UniformGrid>
        </controls:EverythingCard>

        <!-- 不同线宽 -->
        <TextBlock Text="不同线宽" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <UniformGrid Columns="4" Rows="1">
                <controls:EverythingCircularProgressBar Value="60" StrokeThickness="4" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="60" StrokeThickness="8" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="60" StrokeThickness="12" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="60" StrokeThickness="16" Margin="10"/>
            </UniformGrid>
        </controls:EverythingCard>

        <!-- 不同尺寸 -->
        <TextBlock Text="不同尺寸" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <controls:EverythingCircularProgressBar Value="75" Width="60" Height="60" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="75" Width="80" Height="80" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="75" Width="100" Height="100" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="75" Width="120" Height="120" Margin="10"/>
                <controls:EverythingCircularProgressBar Value="75" Width="150" Height="150" Margin="10"/>
            </StackPanel>
        </controls:EverythingCard>

        <!-- 动态进度演示 -->
        <TextBlock Text="动态进度演示" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <StackPanel HorizontalAlignment="Center">
                <controls:EverythingCircularProgressBar x:Name="AnimatedCircularProgressBar" 
                                                        Value="0" 
                                                        ShowPercentage="True"
                                                        Width="120" 
                                                        Height="120"
                                                        Margin="0,0,0,15"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <controls:EverythingButton Content="开始" 
                                               Click="StartButton_Click"
                                               Margin="0,0,10,0"/>
                    <controls:EverythingButton Content="暂停" 
                                               Click="PauseButton_Click"
                                               Margin="0,0,10,0"/>
                    <controls:EverythingButton Content="重置" 
                                               Click="ResetButton_Click"/>
                </StackPanel>
            </StackPanel>
        </controls:EverythingCard>
    </StackPanel>
</UserControl>
