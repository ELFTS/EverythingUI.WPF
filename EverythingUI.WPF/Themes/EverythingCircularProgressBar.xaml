<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <Style TargetType="controls:EverythingCircularProgressBar">
        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="100"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingCircularProgressBar">
                    <Grid>
                        <Ellipse Fill="Transparent"
                                 Stroke="{DynamicResource GlobalTrackBrush}"
                                 StrokeThickness="{TemplateBinding StrokeThickness}"
                                 SnapsToDevicePixels="True"/>
                        <Path x:Name="ProgressPath"
                              Fill="Transparent"
                              SnapsToDevicePixels="True"
                              StrokeThickness="{TemplateBinding StrokeThickness}"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round">
                            <Path.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="{DynamicResource GlobalGradientStartColor}"/>
                                    <GradientStop Offset="0.5" Color="{DynamicResource GlobalGradientEndColor}"/>
                                    <GradientStop Offset="1" Color="{DynamicResource GlobalGradientStartColor}"/>
                                </LinearGradientBrush>
                            </Path.Stroke>
                        </Path>
                        <TextBlock x:Name="PercentageText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Visibility="Collapsed"
                                   Text="{Binding AnimatedValue, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:F0}%}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowPercentage" Value="True">
                            <Setter TargetName="PercentageText" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding AnimatedValue, RelativeSource={RelativeSource TemplatedParent}}" Value="0">
                            <Setter TargetName="ProgressPath" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
