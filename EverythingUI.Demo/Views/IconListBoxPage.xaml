<UserControl x:Class="EverythingUI.Demo.Views.IconListBoxPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
    <UserControl.Resources>
        <!-- 共享 BitmapImage 资源 -->
        <BitmapImage x:Key="TestIcon" UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>

        <!-- 应用启动器样式（9 项） -->
        <x:Array x:Key="LauncherItems" Type="controls:EverythingIconListBoxItem">
            <controls:EverythingIconListBoxItem Text="磁盘空间分析" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="文件重命名" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="文件搜索" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="查找重复文件" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="Hash计算工具" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="文件粉碎机" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="解除文件占用" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="LocalSend" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="SpaceSniffer" Icon="{StaticResource TestIcon}"/>
        </x:Array>
        <x:Array x:Key="SmallItems" Type="controls:EverythingIconListBoxItem">
            <controls:EverythingIconListBoxItem Text="设置" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="工具" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="帮助" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="关于" Icon="{StaticResource TestIcon}"/>
        </x:Array>
        <x:Array x:Key="LargeItems" Type="controls:EverythingIconListBoxItem">
            <controls:EverythingIconListBoxItem Text="文档" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="图片" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="音乐" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="视频" Icon="{StaticResource TestIcon}"/>
        </x:Array>
        <x:Array x:Key="WrapItems" Type="controls:EverythingIconListBoxItem">
            <controls:EverythingIconListBoxItem Text="系统设置中心" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="网络连接管理" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="用户账户控制" Icon="{StaticResource TestIcon}"/>
            <controls:EverythingIconListBoxItem Text="磁盘清理工具" Icon="{StaticResource TestIcon}"/>
        </x:Array>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,40">
            <TextBlock Text="图标列表框控件" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <TextBlock Text="网格布局（类似应用启动器）" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" Opacity="0.8"/>
            <controls:EverythingCard CardVariant="Elevated" Padding="20" Margin="0,0,0,30">
                <controls:EverythingIconListBox ItemWidth="100" ItemHeight="100" IconSize="32" TextFontSize="12" IconTextSpacing="6" CornerRadius="12"
                                                ItemsSource="{StaticResource LauncherItems}"/>
            </controls:EverythingCard>

            <TextBlock Text="不同尺寸配置" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" Opacity="0.8"/>
            <controls:EverythingCard CardVariant="Elevated" Padding="20" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="小尺寸 (ItemWidth=60, ItemHeight=60, IconSize=20, TextFontSize=10)" FontSize="12" Margin="0,0,0,10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <controls:EverythingIconListBox ItemWidth="60" ItemHeight="60" IconSize="20" TextFontSize="10" IconTextSpacing="4" CornerRadius="8" Margin="0,0,0,20"
                                                    ItemsSource="{StaticResource SmallItems}"/>
                    <TextBlock Text="大尺寸 (ItemWidth=120, ItemHeight=120, IconSize=48, TextFontSize=14)" FontSize="12" Margin="0,0,0,10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <controls:EverythingIconListBox ItemWidth="120" ItemHeight="120" IconSize="48" TextFontSize="14" IconTextSpacing="8" CornerRadius="16"
                                                    ItemsSource="{StaticResource LargeItems}"/>
                </StackPanel>
            </controls:EverythingCard>

            <TextBlock Text="文字换行示例" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" Opacity="0.8"/>
            <controls:EverythingCard CardVariant="Elevated" Padding="20" Margin="0,0,0,30">
                <controls:EverythingIconListBox ItemWidth="80" ItemHeight="90" IconSize="28" TextFontSize="11" IconTextSpacing="6" CornerRadius="10"
                                                ItemsSource="{StaticResource WrapItems}"/>
            </controls:EverythingCard>
        </StackPanel>
    </ScrollViewer>
</UserControl>
