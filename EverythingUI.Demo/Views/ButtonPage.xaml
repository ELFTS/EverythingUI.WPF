<UserControl x:Class="EverythingUI.Demo.Views.ButtonPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
    <StackPanel>
        <TextBlock Text="按钮控件" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

        <!-- 基础按钮 -->
        <TextBlock Text="基础按钮（悬停外阴影，按下内阴影）" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated" Padding="20" Margin="0,0,0,20">
            <WrapPanel>
                <controls:EverythingButton x:Name="DefaultButton" Text="默认按钮" Margin="0,0,10,10"/>
                <controls:EverythingButton x:Name="IconButton" Text="带图标的按钮" Margin="0,0,10,10"/>
                <controls:EverythingButton x:Name="PaddingButton" Text="图标按钮" Padding="12" Margin="0,0,10,10"/>
            </WrapPanel>
        </controls:EverythingCard>

        <!-- 胶囊按钮和长按按钮 -->
        <TextBlock Text="胶囊按钮与长按触发" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated" Padding="20" Margin="0,0,0,20">
            <WrapPanel>
                <controls:EverythingButton Text="胶囊按钮" IsCapsule="True" Padding="24,8" Margin="0,0,10,10"/>
                <controls:EverythingButton Text="长按触发" IsLongPressEnabled="True" LongPressDuration="0:0:0.8" Click="LongPressButton_Click" Margin="0,0,10,10"/>
            </WrapPanel>
        </controls:EverythingCard>
    </StackPanel>
</UserControl>
