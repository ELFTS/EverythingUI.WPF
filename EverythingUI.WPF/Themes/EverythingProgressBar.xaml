<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <controls:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>

    <Style TargetType="controls:EverythingProgressBar">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingProgressBar">
                    <Grid x:Name="RootGrid" ClipToBounds="True">
                        <!-- 轨道背景 -->
                        <Border x:Name="TrackBorder" Background="{DynamicResource GlobalTrackBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}" SnapsToDevicePixels="True"/>
                        <!-- 进度条区域（宽度由控件代码以阻力感动画驱动） -->
                        <Grid x:Name="ProgressGrid" HorizontalAlignment="Left" ClipToBounds="True">
                            <!-- 渐变填充 -->
                            <Border x:Name="ProgressBorder" CornerRadius="{TemplateBinding CornerRadius}" SnapsToDevicePixels="True"
                                    HorizontalAlignment="Left" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                                    Height="{TemplateBinding Height}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="{DynamicResource GlobalGradientStartColor}"/>
                                        <GradientStop Offset="0.5" Color="{DynamicResource GlobalGradientEndColor}"/>
                                        <GradientStop Offset="1" Color="{DynamicResource GlobalGradientStartColor}"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.3" Color="Gray" RenderingBias="Quality"/>
                                </Border.Effect>
                            </Border>
                            <!-- 光泽层 -->
                            <Border Background="{DynamicResource GlossBrush}" VerticalAlignment="Top" ClipToBounds="True" IsHitTestVisible="False"
                                    Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}, Converter={x:Static controls:HalfHeightConverter.Instance}}"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <!-- 扫光动画 -->
                            <Rectangle x:Name="SweepLight" Width="{Binding ActualWidth, ElementName=RootGrid}" Height="{TemplateBinding Height}">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0" x:Name="SweepBrush">
                                        <GradientStop Offset="0" Color="Transparent"/>
                                        <GradientStop Offset="0.35" Color="Transparent"/>
                                        <GradientStop Offset="0.42" Color="#30FFFFFF"/>
                                        <GradientStop Offset="0.5" Color="#90FFFFFF"/>
                                        <GradientStop Offset="0.58" Color="#30FFFFFF"/>
                                        <GradientStop Offset="0.65" Color="Transparent"/>
                                        <GradientStop Offset="1" Color="Transparent"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <PointAnimation Storyboard.TargetName="SweepBrush" Storyboard.TargetProperty="StartPoint" From="-1,0" To="2,0" Duration="0:0:2.8"/>
                                                <PointAnimation Storyboard.TargetName="SweepBrush" Storyboard.TargetProperty="EndPoint" From="0,0" To="3,0" Duration="0:0:2.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                        </Grid>
                        <!-- 百分比文本 -->
                        <TextBlock x:Name="PercentageText" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}" FontSize="10" FontWeight="SemiBold" Visibility="Collapsed"
                                   Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:F0}%}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowPercentage" Value="True">
                            <Setter TargetName="PercentageText" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
