<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <FontFamily x:Key="FontFamilyBase">Segoe UI, Microsoft YaHei, PingFang SC, sans-serif</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Consolas, Monaco, Courier New, monospace</FontFamily>

    <system:Double x:Key="FontSizeXs">10</system:Double>
    <system:Double x:Key="FontSizeSm">12</system:Double>
    <system:Double x:Key="FontSizeBase">14</system:Double>
    <system:Double x:Key="FontSizeLg">16</system:Double>
    <system:Double x:Key="FontSizeXl">18</system:Double>
    <system:Double x:Key="FontSize2xl">20</system:Double>
    <system:Double x:Key="FontSize3xl">24</system:Double>
    <system:Double x:Key="FontSize4xl">30</system:Double>

    <FontWeight x:Key="FontWeightNormal">Normal</FontWeight>
    <FontWeight x:Key="FontWeightMedium">Medium</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>

    <system:Double x:Key="LineHeightTight">1.25</system:Double>
    <system:Double x:Key="LineHeightNormal">1.5</system:Double>
    <system:Double x:Key="LineHeightRelaxed">1.75</system:Double>
</ResourceDictionary>
