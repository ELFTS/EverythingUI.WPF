<UserControl x:Class="EverythingUI.Demo.Views.SideBarPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">

    <StackPanel>
        <TextBlock Text="侧边栏控件"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,20"/>

        <TextBlock Text="基础侧边栏" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <Border Height="300" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <controls:EverythingSideBar Grid.Column="0"
                                                SideBarWidth="200"
                                                CornerRadius="0,12,12,0">
                        <controls:EverythingSideBar.ItemsSource>
                            <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                <controls:EverythingSideBarItem Text="首页"/>
                                <controls:EverythingSideBarItem Text="产品管理"/>
                                <controls:EverythingSideBarItem Text="订单管理"/>
                                <controls:EverythingSideBarItem Text="用户管理"/>
                                <controls:EverythingSideBarItem Text="系统设置"/>
                            </x:Array>
                        </controls:EverythingSideBar.ItemsSource>
                    </controls:EverythingSideBar>

                    <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}" Padding="20">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="主内容区域"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </controls:EverythingCard>

        <TextBlock Text="不同颜色方案（使用颜色资源名称）" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <UniformGrid Columns="4" Rows="1">
                <Border Height="150" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <controls:EverythingSideBar SideBarWidth="140" CornerRadius="0,8,8,0">
                        <controls:EverythingSideBar.ItemsSource>
                            <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                <controls:EverythingSideBarItem Text="首页"/>
                                <controls:EverythingSideBarItem Text="产品"/>
                                <controls:EverythingSideBarItem Text="订单"/>
                            </x:Array>
                        </controls:EverythingSideBar.ItemsSource>
                    </controls:EverythingSideBar>
                </Border>

                <Border Height="150" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <controls:EverythingSideBar SideBarWidth="140"
                                                CornerRadius="0,8,8,0"
                                                GradientStartColor="{StaticResource GradientRedStart}"
                                                GradientEndColor="{StaticResource GradientRedEnd}">
                        <controls:EverythingSideBar.ItemsSource>
                            <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                <controls:EverythingSideBarItem Text="首页"/>
                                <controls:EverythingSideBarItem Text="产品"/>
                                <controls:EverythingSideBarItem Text="订单"/>
                            </x:Array>
                        </controls:EverythingSideBar.ItemsSource>
                    </controls:EverythingSideBar>
                </Border>

                <Border Height="150" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <controls:EverythingSideBar SideBarWidth="140"
                                                CornerRadius="0,8,8,0"
                                                GradientStartColor="{StaticResource GradientGreenStart}"
                                                GradientEndColor="{StaticResource GradientGreenEnd}">
                        <controls:EverythingSideBar.ItemsSource>
                            <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                <controls:EverythingSideBarItem Text="首页"/>
                                <controls:EverythingSideBarItem Text="产品"/>
                                <controls:EverythingSideBarItem Text="订单"/>
                            </x:Array>
                        </controls:EverythingSideBar.ItemsSource>
                    </controls:EverythingSideBar>
                </Border>

                <Border Height="150" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <controls:EverythingSideBar SideBarWidth="140"
                                                CornerRadius="0,8,8,0"
                                                GradientStartColor="{StaticResource GradientOrangeStart}"
                                                GradientEndColor="{StaticResource GradientOrangeEnd}">
                        <controls:EverythingSideBar.ItemsSource>
                            <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                <controls:EverythingSideBarItem Text="首页"/>
                                <controls:EverythingSideBarItem Text="产品"/>
                                <controls:EverythingSideBarItem Text="订单"/>
                            </x:Array>
                        </controls:EverythingSideBar.ItemsSource>
                    </controls:EverythingSideBar>
                </Border>
            </UniformGrid>
        </controls:EverythingCard>

        <TextBlock Text="高度限制与外部滚动条" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="SideBarHeight=200（限制高度）" 
                               FontWeight="Medium" 
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Border Height="200" 
                            BorderBrush="{DynamicResource Gray300Brush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:EverythingSideBar Grid.Column="0"
                                                        SideBarWidth="160"
                                                        SideBarHeight="200"
                                                        CornerRadius="0,8,8,0">
                                <controls:EverythingSideBar.ItemsSource>
                                    <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                        <controls:EverythingSideBarItem Text="首页"/>
                                        <controls:EverythingSideBarItem Text="产品管理"/>
                                        <controls:EverythingSideBarItem Text="订单管理"/>
                                        <controls:EverythingSideBarItem Text="用户管理"/>
                                        <controls:EverythingSideBarItem Text="系统设置"/>
                                        <controls:EverythingSideBarItem Text="数据统计"/>
                                        <controls:EverythingSideBarItem Text="消息通知"/>
                                        <controls:EverythingSideBarItem Text="帮助中心"/>
                                    </x:Array>
                                </controls:EverythingSideBar.ItemsSource>
                            </controls:EverythingSideBar>
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
                                <TextBlock Text="内容区域" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock Text="滚动条显示在按钮区域外面 →" 
                               FontSize="12"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontStyle="Italic"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="SideBarHeight=NaN（自动高度）" 
                               FontWeight="Medium" 
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Border MinHeight="200"
                            BorderBrush="{DynamicResource Gray300Brush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:EverythingSideBar Grid.Column="0"
                                                        SideBarWidth="160"
                                                        CornerRadius="0,8,8,0">
                                <controls:EverythingSideBar.ItemsSource>
                                    <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                        <controls:EverythingSideBarItem Text="首页"/>
                                        <controls:EverythingSideBarItem Text="产品管理"/>
                                        <controls:EverythingSideBarItem Text="订单管理"/>
                                        <controls:EverythingSideBarItem Text="用户管理"/>
                                    </x:Array>
                                </controls:EverythingSideBar.ItemsSource>
                            </controls:EverythingSideBar>
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
                                <TextBlock Text="内容区域" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock Text="内容较少时不显示滚动条" 
                               FontSize="12"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </controls:EverythingCard>

        <TextBlock Text="按钮高度调整" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <UniformGrid Columns="3" Rows="1">
                <Border Height="150" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <StackPanel>
                        <TextBlock Text="默认高度 (44)" 
                                   FontSize="11" 
                                   Margin="8,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <controls:EverythingSideBar SideBarWidth="140" 
                                                    CornerRadius="0,8,8,0">
                            <controls:EverythingSideBar.ItemsSource>
                                <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                    <controls:EverythingSideBarItem Text="首页"/>
                                    <controls:EverythingSideBarItem Text="产品"/>
                                    <controls:EverythingSideBarItem Text="订单"/>
                                </x:Array>
                            </controls:EverythingSideBar.ItemsSource>
                        </controls:EverythingSideBar>
                    </StackPanel>
                </Border>

                <Border Height="150" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <StackPanel>
                        <TextBlock Text="小按钮 (36)" 
                                   FontSize="11" 
                                   Margin="8,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <controls:EverythingSideBar SideBarWidth="140"
                                                    CornerRadius="0,8,8,0"
                                                    ItemHeight="36">
                            <controls:EverythingSideBar.ItemsSource>
                                <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                    <controls:EverythingSideBarItem Text="首页"/>
                                    <controls:EverythingSideBarItem Text="产品"/>
                                    <controls:EverythingSideBarItem Text="订单"/>
                                </x:Array>
                            </controls:EverythingSideBar.ItemsSource>
                        </controls:EverythingSideBar>
                    </StackPanel>
                </Border>

                <Border Height="150" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <StackPanel>
                        <TextBlock Text="大按钮 (56)" 
                                   FontSize="11" 
                                   Margin="8,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <controls:EverythingSideBar SideBarWidth="140"
                                                    CornerRadius="0,8,8,0"
                                                    ItemHeight="56">
                            <controls:EverythingSideBar.ItemsSource>
                                <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                    <controls:EverythingSideBarItem Text="首页"/>
                                    <controls:EverythingSideBarItem Text="产品"/>
                                    <controls:EverythingSideBarItem Text="订单"/>
                                </x:Array>
                            </controls:EverythingSideBar.ItemsSource>
                        </controls:EverythingSideBar>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </controls:EverythingCard>

        <TextBlock Text="图标示例 (ImageSource)" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Height="250" 
                        BorderBrush="{DynamicResource Gray300Brush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:EverythingSideBar Grid.Column="0"
                                                    SideBarWidth="100"
                                                    ItemHeight="72"
                                                    ItemDisplayMode="IconTop"
                                                    CornerRadius="0,8,8,0">
                            <controls:EverythingSideBar.ItemsSource>
                                <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                    <controls:EverythingSideBarItem Text="首页">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="产品">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="订单">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="用户">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="设置">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                </x:Array>
                            </controls:EverythingSideBar.ItemsSource>
                        </controls:EverythingSideBar>
                        <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
                            <TextBlock Text="内容区域" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </controls:EverythingCard>

        <TextBlock Text="图标在左示例 (IconLeft)" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <Border Height="200" 
                    BorderBrush="{DynamicResource Gray300Brush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <controls:EverythingSideBar Grid.Column="0"
                                                SideBarWidth="180"
                                                ItemDisplayMode="IconLeft"
                                                CornerRadius="0,8,8,0">
                        <controls:EverythingSideBar.ItemsSource>
                            <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                <controls:EverythingSideBarItem Text="首页">
                                    <controls:EverythingSideBarItem.Icon>
                                        <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                    </controls:EverythingSideBarItem.Icon>
                                </controls:EverythingSideBarItem>
                                <controls:EverythingSideBarItem Text="产品管理">
                                    <controls:EverythingSideBarItem.Icon>
                                        <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                    </controls:EverythingSideBarItem.Icon>
                                </controls:EverythingSideBarItem>
                                <controls:EverythingSideBarItem Text="订单管理">
                                    <controls:EverythingSideBarItem.Icon>
                                        <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                    </controls:EverythingSideBarItem.Icon>
                                </controls:EverythingSideBarItem>
                                <controls:EverythingSideBarItem Text="系统设置">
                                    <controls:EverythingSideBarItem.Icon>
                                        <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                    </controls:EverythingSideBarItem.Icon>
                                </controls:EverythingSideBarItem>
                            </x:Array>
                        </controls:EverythingSideBar.ItemsSource>
                    </controls:EverythingSideBar>
                    <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
                        <TextBlock Text="内容区域" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                </Grid>
            </Border>
        </controls:EverythingCard>

        <TextBlock Text="图标大小设置" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <UniformGrid Columns="3" Rows="1">
                <Border Height="200" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <StackPanel>
                        <TextBlock Text="小图标 (16x16)" 
                                   FontSize="11" 
                                   Margin="8,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <controls:EverythingSideBar SideBarWidth="90" 
                                                    ItemHeight="60"
                                                    ItemDisplayMode="IconTop"
                                                    CornerRadius="0,8,8,0">
                            <controls:EverythingSideBar.ItemsSource>
                                <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                    <controls:EverythingSideBarItem Text="首页" IconWidth="16" IconHeight="16">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="产品" IconWidth="16" IconHeight="16">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="订单" IconWidth="16" IconHeight="16">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                </x:Array>
                            </controls:EverythingSideBar.ItemsSource>
                        </controls:EverythingSideBar>
                    </StackPanel>
                </Border>

                <Border Height="200" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <StackPanel>
                        <TextBlock Text="默认图标 (22x22)" 
                                   FontSize="11" 
                                   Margin="8,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <controls:EverythingSideBar SideBarWidth="90"
                                                    ItemHeight="60"
                                                    ItemDisplayMode="IconTop"
                                                    CornerRadius="0,8,8,0">
                            <controls:EverythingSideBar.ItemsSource>
                                <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                    <controls:EverythingSideBarItem Text="首页">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="产品">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="订单">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                </x:Array>
                            </controls:EverythingSideBar.ItemsSource>
                        </controls:EverythingSideBar>
                    </StackPanel>
                </Border>

                <Border Height="200" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <StackPanel>
                        <TextBlock Text="大图标 (32x32)" 
                                   FontSize="11" 
                                   Margin="8,4"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <controls:EverythingSideBar SideBarWidth="90"
                                                    ItemHeight="72"
                                                    ItemDisplayMode="IconTop"
                                                    CornerRadius="0,8,8,0">
                            <controls:EverythingSideBar.ItemsSource>
                                <x:Array Type="controls:EverythingSideBarItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                                    <controls:EverythingSideBarItem Text="首页" IconWidth="32" IconHeight="32">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="产品" IconWidth="32" IconHeight="32">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                    <controls:EverythingSideBarItem Text="订单" IconWidth="32" IconHeight="32">
                                        <controls:EverythingSideBarItem.Icon>
                                            <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                        </controls:EverythingSideBarItem.Icon>
                                    </controls:EverythingSideBarItem>
                                </x:Array>
                            </controls:EverythingSideBar.ItemsSource>
                        </controls:EverythingSideBar>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </controls:EverythingCard>
    </StackPanel>
</UserControl>
