<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <Style TargetType="controls:EverythingToggleSwitch">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingToggleSwitch">
                    <Grid x:Name="rootGrid">
                        <Grid x:Name="switchContainer" VerticalAlignment="Center"
                              Width="{TemplateBinding SwitchWidth}" Height="{TemplateBinding SwitchHeight}">
                            <Border x:Name="trackShadow" Background="White" CornerRadius="4" SnapsToDevicePixels="True" IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.25" Color="Black" RenderingBias="Quality"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="trackBackground" Background="{TemplateBinding UncheckedBackground}" CornerRadius="4" SnapsToDevicePixels="True"/>
                            <Border x:Name="checkedBackground" CornerRadius="4" SnapsToDevicePixels="True" Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="{DynamicResource GlobalGradientStartColor}"/>
                                        <GradientStop Offset="0.5" Color="{DynamicResource GlobalGradientEndColor}"/>
                                        <GradientStop Offset="1" Color="{DynamicResource GlobalGradientStartColor}"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border Background="{DynamicResource GlossBrush}" CornerRadius="4" VerticalAlignment="Top" ClipToBounds="True" IsHitTestVisible="False"
                                        Height="{Binding ActualHeight, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static controls:HalfHeightConverter.Instance}}"/>
                            </Border>
                            <Canvas x:Name="thumbCanvas" Margin="3,2">
                                <Border x:Name="thumb" Canvas.Left="0" Canvas.Top="0"
                                        Width="{TemplateBinding ThumbSize}" Height="{TemplateBinding ThumbSize}"
                                        CornerRadius="3" Background="{TemplateBinding ThumbBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.35" Color="Black" RenderingBias="Quality"/>
                                    </Border.Effect>
                                </Border>
                            </Canvas>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="checkedBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="trackBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="thumb" Storyboard.TargetProperty="(Canvas.Left)" To="24" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction><ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="5"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="checkedBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="trackBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="thumb" Storyboard.TargetProperty="(Canvas.Left)" To="0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction><ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="5"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
