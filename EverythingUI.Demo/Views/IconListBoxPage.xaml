                    <Border Height="220" Margin="5" BorderBrush="{DynamicResource Gray300Brush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                        <StackPanel>
                            <TextBlock Text="红色" 
                                       FontSize="11" 
                                       Margin="8,4"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <controls:EverythingIconListBox Height="180"
                                                            ItemWidth="80"
                                                            ItemHeight="80"
                                                            IconSize="28"
                                                            TextFontSize="12"
                                                            CornerRadius="8"
