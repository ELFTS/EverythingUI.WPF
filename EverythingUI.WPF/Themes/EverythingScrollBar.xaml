<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 垂直三色渐变 (从上到下) -->
    <LinearGradientBrush x:Key="ThumbVerticalGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F0F0F0" Offset="0.5"/>
        <GradientStop Color="#E0E0E0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ThumbVerticalHoverGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F8F8F8" Offset="0"/>
        <GradientStop Color="#E8E8E8" Offset="0.5"/>
        <GradientStop Color="#D8D8D8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ThumbVerticalPressedGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E8E8E8" Offset="0"/>
        <GradientStop Color="#D8D8D8" Offset="0.5"/>
        <GradientStop Color="#C8C8C8" Offset="1"/>
    </LinearGradientBrush>

    <!-- 水平三色渐变 (从左到右) -->
    <LinearGradientBrush x:Key="ThumbHorizontalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F0F0F0" Offset="0.5"/>
        <GradientStop Color="#E0E0E0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ThumbHorizontalHoverGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F8F8F8" Offset="0"/>
        <GradientStop Color="#E8E8E8" Offset="0.5"/>
        <GradientStop Color="#D8D8D8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ThumbHorizontalPressedGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E8E8E8" Offset="0"/>
        <GradientStop Color="#D8D8D8" Offset="0.5"/>
        <GradientStop Color="#C8C8C8" Offset="1"/>
    </LinearGradientBrush>

    <!-- 滑块槽背景渐变 -->
    <LinearGradientBrush x:Key="TrackBackgroundBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E8E8E8" Offset="0"/>
        <GradientStop Color="#F5F5F5" Offset="0.5"/>
        <GradientStop Color="#E8E8E8" Offset="1"/>
    </LinearGradientBrush>

    <!-- 箭头按钮样式 -->
    <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#40FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 垂直滚动条滑块样式 -->
    <Style x:Key="EverythingVerticalScrollBarThumb" TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource ThumbVerticalGradientBrush}"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="thumbBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.3" Color="Black" RenderingBias="Quality"/>
                        </Border.Effect>
                        <!-- 三个横杆 -->
                        <StackPanel x:Name="gripLines"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Vertical"
                                    Margin="0,2">
                            <Rectangle Width="12" Height="1.5" Fill="#999999" Margin="0,1.5"/>
                            <Rectangle Width="12" Height="1.5" Fill="#999999" Margin="0,1.5"/>
                            <Rectangle Width="12" Height="1.5" Fill="#999999" Margin="0,1.5"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ThumbVerticalHoverGradientBrush}"/>
                            <Setter TargetName="thumbBorder" Property="BorderBrush" Value="#BBBBBB"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ThumbVerticalPressedGradientBrush}"/>
                            <Setter TargetName="thumbBorder" Property="BorderBrush" Value="#AAAAAA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 水平滚动条滑块样式 -->
    <Style x:Key="EverythingHorizontalScrollBarThumb" TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource ThumbHorizontalGradientBrush}"/>
        <Setter Property="BorderBrush" Value="#CCCCCC"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="thumbBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.3" Color="Black" RenderingBias="Quality"/>
                        </Border.Effect>
                        <!-- 三个竖杆 -->
                        <StackPanel x:Name="gripLines"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Margin="2,0">
                            <Rectangle Width="1.5" Height="12" Fill="#999999" Margin="1.5,0"/>
                            <Rectangle Width="1.5" Height="12" Fill="#999999" Margin="1.5,0"/>
                            <Rectangle Width="1.5" Height="12" Fill="#999999" Margin="1.5,0"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ThumbHorizontalHoverGradientBrush}"/>
                            <Setter TargetName="thumbBorder" Property="BorderBrush" Value="#BBBBBB"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource ThumbHorizontalPressedGradientBrush}"/>
                            <Setter TargetName="thumbBorder" Property="BorderBrush" Value="#AAAAAA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 垂直滚动条样式 -->
    <Style x:Key="EverythingVerticalScrollBar" TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="22"/>
        <Setter Property="MinWidth" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="GridRoot" Width="22">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 滑块槽背景 -->
                        <Border Grid.Row="0" Grid.RowSpan="3"
                                Background="{StaticResource TrackBackgroundBrush}"
                                CornerRadius="8"
                                Margin="2,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.2" Color="Black" Direction="270" RenderingBias="Quality"/>
                            </Border.Effect>
                        </Border>

                        <!-- 上箭头按钮 -->
                        <RepeatButton x:Name="LineUpButton"
                                      Grid.Row="0"
                                      Style="{StaticResource ScrollBarButtonStyle}"
                                      Command="ScrollBar.LineUpCommand">
                            <Path x:Name="ArrowUp"
                                  Data="M 0,4 L 4,0 L 8,4"
                                  Stroke="#666666"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </RepeatButton>

                        <!-- 中间轨道 -->
                        <Track x:Name="PART_Track"
                               Grid.Row="1"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{DynamicResource EverythingVerticalScrollBarThumb}"
                                       Margin="2,0"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                        </Track>

                        <!-- 下箭头按钮 -->
                        <RepeatButton x:Name="LineDownButton"
                                      Grid.Row="2"
                                      Style="{StaticResource ScrollBarButtonStyle}"
                                      Command="ScrollBar.LineDownCommand">
                            <Path x:Name="ArrowDown"
                                  Data="M 0,0 L 4,4 L 8,0"
                                  Stroke="#666666"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </RepeatButton>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 水平滚动条样式 -->
    <Style x:Key="EverythingHorizontalScrollBar" TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="GridRoot" Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 滑块槽背景 -->
                        <Border Grid.Column="0" Grid.ColumnSpan="3"
                                Background="{StaticResource TrackBackgroundBrush}"
                                CornerRadius="8"
                                Margin="0,2">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.2" Color="Black" Direction="0" RenderingBias="Quality"/>
                            </Border.Effect>
                        </Border>

                        <!-- 左箭头按钮 -->
                        <RepeatButton x:Name="LineLeftButton"
                                      Grid.Column="0"
                                      Style="{StaticResource ScrollBarButtonStyle}"
                                      Command="ScrollBar.LineLeftCommand">
                            <Path x:Name="ArrowLeft"
                                  Data="M 4,0 L 0,4 L 4,8"
                                  Stroke="#666666"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </RepeatButton>

                        <!-- 中间轨道 -->
                        <Track x:Name="PART_Track"
                               Grid.Column="1">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageLeftCommand"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{DynamicResource EverythingHorizontalScrollBarThumb}"
                                       Margin="0,2"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageRightCommand"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                        </Track>

                        <!-- 右箭头按钮 -->
                        <RepeatButton x:Name="LineRightButton"
                                      Grid.Column="2"
                                      Style="{StaticResource ScrollBarButtonStyle}"
                                      Command="ScrollBar.LineRightCommand">
                            <Path x:Name="ArrowRight"
                                  Data="M 0,0 L 4,4 L 0,8"
                                  Stroke="#666666"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </RepeatButton>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollViewer 样式 -->
    <Style x:Key="EverythingScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 内容区域 -->
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                Content="{TemplateBinding Content}"
                                                Margin="{TemplateBinding Padding}"/>

                        <!-- 垂直滚动条 -->
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Style="{DynamicResource EverythingVerticalScrollBar}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Cursor="Arrow"/>

                        <!-- 水平滚动条 -->
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Row="1"
                                   Grid.Column="0"
                                   Style="{DynamicResource EverythingHorizontalScrollBar}"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                   Cursor="Arrow"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
