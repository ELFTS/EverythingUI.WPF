<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <controls:ColorToBrushConverter x:Key="ColorToBrushConverter"/>

    <Style TargetType="controls:EverythingCircularProgressBar">
        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="100"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingCircularProgressBar">
                    <Grid>
                        <Ellipse x:Name="TrackEllipse" Fill="Transparent" Stroke="{DynamicResource GlobalTrackBrush}" StrokeThickness="{TemplateBinding StrokeThickness}"/>
                        <Path x:Name="ProgressPath" Fill="Transparent" StrokeThickness="{TemplateBinding StrokeThickness}" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Path.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="{DynamicResource GlobalGradientStartColor}"/>
                                    <GradientStop Offset="0.5" Color="{DynamicResource GlobalGradientEndColor}"/>
                                    <GradientStop Offset="1" Color="{DynamicResource GlobalGradientStartColor}"/>
                                </LinearGradientBrush>
                            </Path.Stroke>
                            <Path.Data>
                                <MultiBinding Converter="{x:Static controls:CircularArcHelper.GeometryConverter}">
                                    <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </MultiBinding>
                            </Path.Data>
                        </Path>
                        <TextBlock x:Name="PercentageText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Visibility="Collapsed">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:F0}%">
                                    <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowPercentage" Value="True">
                            <Setter TargetName="PercentageText" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource TemplatedParent}}" Value="0">
                            <Setter TargetName="ProgressPath" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
