<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/EverythingUI.WPF;component/Themes/EverythingScrollBar.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="EverythingSideBarItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Margin" Value="8,4"/>
        <Setter Property="Height" Value="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=controls:EverythingSideBar}}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <Border x:Name="border" Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" SnapsToDevicePixels="True"/>
                        <ContentPresenter x:Name="contentPresenter"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource Gray200Brush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="EverythingSideBarItemTextOnlyTemplate" DataType="{x:Type controls:EverythingSideBarItem}">
        <TextBlock Text="{Binding Text}" FontSize="14"/>
    </DataTemplate>

    <DataTemplate x:Key="EverythingSideBarItemIconOnlyTemplate" DataType="{x:Type controls:EverythingSideBarItem}">
        <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform"/>
    </DataTemplate>

    <DataTemplate x:Key="EverythingSideBarItemIconLeftTemplate" DataType="{x:Type controls:EverythingSideBarItem}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding Text}" FontSize="14" VerticalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EverythingSideBarItemIconTopTemplate" DataType="{x:Type controls:EverythingSideBarItem}">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform"/>
            <TextBlock Text="{Binding Text}" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>
    </DataTemplate>

    <Style TargetType="controls:EverythingSideBar">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Gray300Brush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingSideBar">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" MaxHeight="{TemplateBinding SideBarHeight}">
                            <Border x:Name="sideBarBorder"
                                    Width="{TemplateBinding SideBarWidth}"
                                    Background="Transparent"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True">
                                <ScrollViewer x:Name="scrollViewer"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <Grid>
                                        <Grid x:Name="selectionSlider"
                                              Opacity="0" IsHitTestVisible="False"
                                              HorizontalAlignment="Left" VerticalAlignment="Top"
                                              RenderOptions.BitmapScalingMode="HighQuality">
                                            <Grid.CacheMode>
                                                <BitmapCache RenderAtScale="1" EnableClearType="False"/>
                                            </Grid.CacheMode>
                                            <Border x:Name="sliderBackground"
                                                    Background="Transparent" CornerRadius="8">
                                                <Border.Effect>
                                                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3" Color="Black" RenderingBias="Quality"/>
                                                </Border.Effect>
                                            </Border>
                                            <Border Background="{DynamicResource GlossBrush}"
                                                    VerticalAlignment="Top" ClipToBounds="True" IsHitTestVisible="False"
                                                    Height="{Binding ActualHeight, RelativeSource={RelativeSource FindAncestor, AncestorType=Grid}, Converter={x:Static controls:HalfHeightConverter.Instance}}"
                                                    CornerRadius="8,8,0,0"/>
                                        </Grid>
                                        <ListBox x:Name="menuListBox"
                                                 ItemsSource="{TemplateBinding ItemsSource}"
                                                 ItemTemplate="{TemplateBinding ItemTemplate}"
                                                 ItemContainerStyle="{DynamicResource EverythingSideBarItemStyle}"
                                                 SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                 Background="Transparent"
                                                 BorderBrush="Transparent"
                                                 BorderThickness="0"
                                                 Margin="0,8"/>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                        <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                   Style="{DynamicResource EverythingVerticalScrollBar}"
                                   Visibility="{Binding ComputedVerticalScrollBarVisibility, ElementName=scrollViewer}"
                                   Maximum="{Binding ScrollableHeight, ElementName=scrollViewer}"
                                   ViewportSize="{Binding ViewportHeight, ElementName=scrollViewer}"
                                   Cursor="Arrow"/>
                        <ContentPresenter Grid.Column="2"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ItemDisplayMode" Value="IconTop">
                            <Setter TargetName="menuListBox" Property="ItemContainerStyle">
                                <Setter.Value>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource EverythingSideBarItemStyle}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingSideBarItemIconTopTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="IconOnly">
                            <Setter TargetName="menuListBox" Property="ItemContainerStyle">
                                <Setter.Value>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource EverythingSideBarItemStyle}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingSideBarItemIconOnlyTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="IconLeft">
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingSideBarItemIconLeftTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="TextOnly">
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingSideBarItemTextOnlyTemplate}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
