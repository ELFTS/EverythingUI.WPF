                                            </controls:EverythingIconListBoxItem.Icon>
                                        </controls:EverythingIconListBoxItem>
                                    </x:Array>
                                </controls:EverythingIconListBox.ItemsSource>
                            </controls:EverythingIconListBox>
                        </StackPanel>
