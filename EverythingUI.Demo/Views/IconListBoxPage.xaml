                        <x:Array Type="controls:EverythingIconListBoxItem" xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
                            <controls:EverythingIconListBoxItem Text="系统设置中心">
                                <controls:EverythingIconListBoxItem.Icon>
                                    <BitmapImage UriSource="pack://application:,,,/EverythingUI.Demo;component/Assets/test.png"/>
                                </controls:EverythingIconListBoxItem.Icon>
                            </controls:EverythingIconListBoxItem>
                            <controls:EverythingIconListBoxItem Text="网络连接管理">
                                <controls:EverythingIconListBoxItem.Icon>
