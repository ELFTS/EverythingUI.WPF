<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:EverythingUI.WPF.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/EverythingUI.WPF;component/Themes/EverythingScrollBar.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="EverythingToolBarHorizontalItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Margin" Value="4,2"/>
        <Setter Property="Height" Value="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid ClipToBounds="False">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True"/>

                        <Border x:Name="gloss"
                                Height="{Binding ActualHeight, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static controls:HalfHeightConverter.Instance}}"
                                VerticalAlignment="Top"
                                CornerRadius="6,6,0,0"
                                Opacity="0"
                                ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#CCFFFFFF"/>
                                    <GradientStop Offset="1" Color="#33FFFFFF"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <ContentPresenter x:Name="contentPresenter"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="{Binding GradientStartColor, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
                                        <GradientStop Offset="0.5" Color="{Binding GradientEndColor, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
                                        <GradientStop Offset="1" Color="{Binding GradientStartColor, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.25" Color="Black" RenderingBias="Quality"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="gloss" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#FFFFFFFF"/>
                                        <GradientStop Offset="0.5" Color="#F5F5F5"/>
                                        <GradientStop Offset="1" Color="#FFFFFFFF"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="0.12" Color="Black" RenderingBias="Quality"/>
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EverythingToolBarVerticalItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="4,2"/>
        <Setter Property="Height" Value="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
        <Setter Property="Width" Value="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid ClipToBounds="False">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True"/>

                        <Border x:Name="gloss"
                                Height="{Binding ActualHeight, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static controls:HalfHeightConverter.Instance}}"
                                VerticalAlignment="Top"
                                CornerRadius="6,6,0,0"
                                Opacity="0"
                                ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#CCFFFFFF"/>
                                    <GradientStop Offset="1" Color="#33FFFFFF"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <ContentPresenter x:Name="contentPresenter"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="{Binding GradientStartColor, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
                                        <GradientStop Offset="0.5" Color="{Binding GradientEndColor, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
                                        <GradientStop Offset="1" Color="{Binding GradientStartColor, RelativeSource={RelativeSource AncestorType=controls:EverythingToolBar}}"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.25" Color="Black" RenderingBias="Quality"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="gloss" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter TargetName="border" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#FFFFFFFF"/>
                                        <GradientStop Offset="0.5" Color="#F5F5F5"/>
                                        <GradientStop Offset="1" Color="#FFFFFFFF"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="0.12" Color="Black" RenderingBias="Quality"/>
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="EverythingToolBarItemTextOnlyTemplate" DataType="{x:Type controls:EverythingToolBarItem}">
        <TextBlock Text="{Binding Text}" FontSize="13"/>
    </DataTemplate>

    <DataTemplate x:Key="EverythingToolBarItemIconOnlyTemplate" DataType="{x:Type controls:EverythingToolBarItem}">
        <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform"/>
    </DataTemplate>

    <DataTemplate x:Key="EverythingToolBarItemIconLeftTemplate" DataType="{x:Type controls:EverythingToolBarItem}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding Text}" FontSize="13" VerticalAlignment="Center"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EverythingToolBarItemIconTopTemplate" DataType="{x:Type controls:EverythingToolBarItem}">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="{Binding Icon}" Width="{Binding IconWidth}" Height="{Binding IconHeight}" Stretch="Uniform"/>
            <TextBlock Text="{Binding Text}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>
    </DataTemplate>

    <Style TargetType="controls:EverythingToolBar">
        <Setter Property="MinHeight" Value="{Binding ToolBarHeight, RelativeSource={RelativeSource Self}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EverythingToolBar">
                    <Grid ClipToBounds="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer x:Name="scrollViewer"
                                      Grid.Row="0"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollBarVisibility="Hidden"
                                      Padding="8,4"
                                      ClipToBounds="False">
                            <ListBox x:Name="menuListBox"
                                     ItemsSource="{TemplateBinding ItemsSource}"
                                     ItemTemplate="{TemplateBinding ItemTemplate}"
                                     ItemContainerStyle="{DynamicResource EverythingToolBarHorizontalItemStyle}"
                                     SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </ScrollViewer>

                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Row="1"
                                   Style="{DynamicResource EverythingHorizontalScrollBar}"
                                   Visibility="{Binding ComputedHorizontalScrollBarVisibility, ElementName=scrollViewer}"
                                   Maximum="{Binding ScrollableWidth, ElementName=scrollViewer}"
                                   ViewportSize="{Binding ViewportWidth, ElementName=scrollViewer}"
                                   Cursor="Arrow"
                                   Orientation="Horizontal"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ItemDisplayMode" Value="IconTop">
                            <Setter TargetName="menuListBox" Property="ItemContainerStyle" Value="{DynamicResource EverythingToolBarVerticalItemStyle}"/>
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingToolBarItemIconTopTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="IconOnly">
                            <Setter TargetName="menuListBox" Property="ItemContainerStyle" Value="{DynamicResource EverythingToolBarVerticalItemStyle}"/>
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingToolBarItemIconOnlyTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="IconLeft">
                            <Setter TargetName="menuListBox" Property="ItemContainerStyle" Value="{DynamicResource EverythingToolBarHorizontalItemStyle}"/>
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingToolBarItemIconLeftTemplate}"/>
                        </Trigger>
                        <Trigger Property="ItemDisplayMode" Value="TextOnly">
                            <Setter TargetName="menuListBox" Property="ItemContainerStyle" Value="{DynamicResource EverythingToolBarHorizontalItemStyle}"/>
                            <Setter TargetName="menuListBox" Property="ItemTemplate" Value="{StaticResource EverythingToolBarItemTextOnlyTemplate}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>