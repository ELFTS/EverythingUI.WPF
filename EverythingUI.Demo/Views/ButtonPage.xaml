<UserControl x:Class="EverythingUI.Demo.Views.ButtonPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF">
    <StackPanel>
        <TextBlock Text="按钮控件"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,20"/>

        <!-- 基础按钮 -->
        <TextBlock Text="基础按钮（悬停外阴影，按下内阴影）"
                   FontWeight="SemiBold"
                   FontSize="16"
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <WrapPanel>
                <controls:EverythingButton Content="默认按钮" Margin="0,0,10,10"/>
                <controls:EverythingButton Content="带图标的按钮" Margin="0,0,10,10"/>
                <controls:EverythingButton Content="图标按钮" Padding="12" Margin="0,0,10,10"/>
            </WrapPanel>
        </controls:EverythingCard>

        <!-- 不同圆角 -->
        <TextBlock Text="不同圆角" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <WrapPanel>
                <controls:EverythingButton Content="小圆角 (4px)" CornerRadius="4" Margin="0,0,10,0"/>
                <controls:EverythingButton Content="中圆角 (8px)" CornerRadius="8" Margin="0,0,10,0"/>
                <controls:EverythingButton Content="大圆角 (16px)" CornerRadius="16"/>
            </WrapPanel>
        </controls:EverythingCard>

        <!-- 预设颜色 -->
        <TextBlock Text="预设颜色方案（使用颜色资源名称）" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,10"
                   Opacity="0.8"/>
        <controls:EverythingCard CardVariant="Elevated"
                                Padding="20"
                                Margin="0,0,0,20">
            <WrapPanel>
                <controls:EverythingButton Content="蓝色 (默认)" Margin="0,0,10,10"/>
                <controls:EverythingButton Content="红色" Margin="0,0,10,10"
                    GradientStartColor="{StaticResource GradientRedStart}"
                    GradientEndColor="{StaticResource GradientRedEnd}"/>
                <controls:EverythingButton Content="绿色" Margin="0,0,10,10"
                    GradientStartColor="{StaticResource GradientGreenStart}"
                    GradientEndColor="{StaticResource GradientGreenEnd}"/>
                <controls:EverythingButton Content="橙色" Margin="0,0,10,10"
                    GradientStartColor="{StaticResource GradientOrangeStart}"
                    GradientEndColor="{StaticResource GradientOrangeEnd}"/>
            </WrapPanel>
        </controls:EverythingCard>
    </StackPanel>
</UserControl>
